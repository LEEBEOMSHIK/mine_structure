{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.unicorn_laptop.lid": {
      "initial_state": "open",
      "states": {
        "open": {
          "animations": [
            "open"
          ],
          "transitions": [
            {
              "closed": "q.variant == 1"
            }
          ]
        },
        "closed": {
          "animations": [
            "closed"
          ],
          "transitions": [
            {
              "open": "q.variant == 0"
            }
          ]
        }
      }
    }
  }
}